{
  "$schema": "https://opencode.ai/config.json",
  "theme": "ayu",
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/gpt-5-mini",
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "webfetch": "allow",
    "read": "allow",
    "write": "allow",
    "lsp": "allow"
  },
  "disabled_providers": [
    "openrouter",
    "synthetic",
    "minimax-cn",
    "minimax-cn-coding-plan",
    "minimax",
    "minimax-coding-plan",
    "github-models",
    // "github-copilot",
    "github-copilot-enterprise"
  ],
  "provider": {
